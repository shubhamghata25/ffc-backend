# ── REQUIRED ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ffc

# ── SECURITY - Generate these once and keep secret ────────────────────────────

# JWT secret for signing admin session tokens (run once to generate):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# Bcrypt hash of your admin password (run once to generate):
#   node -e "const b=require('bcryptjs'); console.log(b.hashSync('yourpassword',12))"
ADMIN_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH

# Your frontend URL (used for CORS - no trailing slash)
FRONTEND_URL=https://ffc-frontend-one.vercel.app

# Admin phone number for SMS alerts
ADMIN_PHONE=8484805154

# ── PAYMENTS ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXX

# ── EMAIL ─────────────────────────────────────────────────────────────────────
# Option A - Brevo (recommended, free 300/day, no port blocking on Render)
BREVO_API_KEY=xkeysib-XXXXXXXXXXXX

# Option B - Gmail SMTP fallback
EMAIL_USER=yourgymemail@gmail.com
EMAIL_PASS=your-16-char-app-password   # NOT your login password

# ── IMAGE STORAGE ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=000000000000
CLOUDINARY_API_SECRET=XXXXXXXXXXXXXXXXXXXX

# ── SMS ───────────────────────────────────────────────────────────────────────
FAST2SMS_API_KEY=XXXXXXXXXXXXXXXXXXXX
