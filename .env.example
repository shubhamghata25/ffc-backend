# ══════════════════════════════════════════════════════
#  FFC Backend — All Environment Variables
#  Add ALL of these to Render → Environment tab
# ══════════════════════════════════════════════════════

# ── MongoDB Atlas (REQUIRED — free forever) ───────────
# Steps to get this:
# 1. Go to mongodb.com/atlas → Sign Up Free
# 2. Create a FREE cluster (M0 Sandbox)
# 3. Database Access → Add user (username + password)
# 4. Network Access → Add IP → Allow from anywhere (0.0.0.0/0)
# 5. Clusters → Connect → Drivers → Copy connection string
# 6. Replace <password> with your DB user password
MONGODB_URI=mongodb+srv://ffc_user:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/ffc?retryWrites=true&w=majority

# ── Cloudinary (REQUIRED — free 25GB) ─────────────────
# 1. cloudinary.com → Sign Up Free
# 2. Dashboard → copy Cloud name, API Key, API Secret
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_api_secret_here

# ── Admin ─────────────────────────────────────────────
ADMIN_PASSWORD=gym@admin123
ADMIN_SECRET=ffc-admin-secret-2026

# ── Keep-alive (add your Render URL after deploy) ─────
# Render Dashboard → ffc-backend → copy the .onrender.com URL
RENDER_EXTERNAL_URL=https://ffc-backend.onrender.com

# ── Razorpay ──────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── Gmail ─────────────────────────────────────────────
EMAIL_USER=friendsfitnessclub18@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── CORS ──────────────────────────────────────────────
FRONTEND_URL=https://ffc-frontend-one.vercel.app

PORT=4000
