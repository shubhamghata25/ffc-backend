# ════════════════════════════════════════════
# FFC Backend — Environment Variables
# ════════════════════════════════════════════

# ── Cloudinary (REQUIRED for permanent image storage) ─────────
# Sign up FREE at https://cloudinary.com
# Dashboard → API Keys → Copy all three values
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_api_secret_here

# ── Admin credentials ─────────────────────────────────────────
# Admin login username (default: admin)
ADMIN_USERNAME=admin
# Admin password (plain text — hashed by bcrypt on startup)
ADMIN_PASSWORD=gym@admin123
# OR set a pre-hashed password (run: node -e "const b=require('bcryptjs');console.log(b.hashSync('yourpass',10))")
# ADMIN_PASSWORD_HASH=$2b$10$...

# ── Admin API key (must match VITE_ADMIN_SECRET in Vercel) ────
ADMIN_SECRET=ffc-admin-secret-2026

# ── Razorpay ─────────────────────────────────────────────────
# Get from: razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── Gmail (for contact form email alerts) ────────────────────
# App Password: myaccount.google.com → Security → App Passwords
EMAIL_USER=friendsfitnessclub18@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── CORS ─────────────────────────────────────────────────────
FRONTEND_URL=https://ffc-frontend-one.vercel.app

PORT=4000
